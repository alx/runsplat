{
  "tests": [
    {
      "name": "short_video_to_ply",
      "input": {
        "video_url": "https://github.com/alx/runsplat/releases/download/v0.1.5/lighthouse.mp4",
        "steps": 5000
      },
      "timeout": 900000
    }
  ],
  "config": {
    "gpuTypeId": "NVIDIA GeForce RTX 4090",
    "gpuCount": 1,
    "env": [
      {
        "key": "TRAINING_STEPS",
        "value": "5000"
      },
      {
        "key": "MATCHING_TYPE",
        "value": "sequential"
      }
    ],
    "allowedCudaVersions": [
      "12.9", "12.8", "12.7", "12.6", "12.5"
    ]
  }
}
